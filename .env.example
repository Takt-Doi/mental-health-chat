# =====================================================
# こころのサポートAI - 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local
# =====================================================

# 合言葉（アクセスに必要なパスワード）
# デフォルトは "test" ですが、本番環境では必ず変更してください
PASSPHRASE=test

# セッション署名用の秘密鍵
# 32文字以上のランダムな文字列を設定してください
# 生成例: openssl rand -base64 32
SESSION_SECRET=

# Anthropic APIキー
# https://console.anthropic.com/ で取得してください
ANTHROPIC_API_KEY=

# アプリのベースURL（ログアウトのリダイレクト先）
# Vercelデプロイ時は自動設定されるため通常は不要
# NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
